# DO NOT COMMIT THE ACTUAL .env FILE!
# Copy this file to .env and fill in the values

# Required for Render Deployment
NODE_ENV=production
# Let Render assign the port automatically, or set it explicitly (e.g., 10000)
PORT=10000
# Generate a long, random 64-character string for production session security
SESSION_SECRET=replace_with_64_character_random_secret
ADMIN_USERNAME=replace_with_admin_username
ADMIN_PASSWORD=replace_with_strong_password
# Your custom domain or Render URL
SITE_URL=https://your-render-domain-or-custom-domain.com

# Optional (Tracking)
FB_PIXEL_ID=optional
