<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= content.seoTitle || 'Nền tảng giao dịch Forex & Prop Firm chuyên nghiệp cho Trader' %></title>
    <meta name="description" content="<%= content.seoDescription || 'Khám phá nền tảng giao dịch tài chính dành cho trader: điều kiện giao dịch minh bạch, công nghệ khớp lệnh nhanh, chương trình cấp vốn Prop Firm.' %>">
    
    <link rel="canonical" href="<%= siteUrl %>/">
    <meta name="robots" content="index,follow">

    <!-- Open Graph -->
    <meta property="og:title" content="<%= content.seoTitle || 'Nền tảng giao dịch Forex & Prop Firm chuyên nghiệp cho Trader' %>">
    <meta property="og:description" content="<%= content.seoDescription || 'Khám phá nền tảng giao dịch tài chính dành cho trader: điều kiện giao dịch minh bạch, công nghệ khớp lệnh nhanh, chương trình cấp vốn Prop Firm.' %>">
    <meta property="og:url" content="<%= siteUrl %>/">
    <meta property="og:type" content="website">
    <% if (content.ogImage) { %>
    <meta property="og:image" content="<%= content.ogImage %>">
    <% } %>

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content.seoTitle || 'Nền tảng giao dịch Forex & Prop Firm chuyên nghiệp cho Trader' %>">
    <meta name="twitter:description" content="<%= content.seoDescription || 'Khám phá nền tảng giao dịch tài chính dành cho trader: điều kiện giao dịch minh bạch, công nghệ khớp lệnh nhanh, chương trình cấp vốn Prop Firm.' %>">
    <% if (content.ogImage) { %>
    <meta name="twitter:image" content="<%= content.ogImage %>">
    <% } %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">

    <!-- JSON-LD -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "<%= content.brandName || 'Trường Giang' %>",
      "url": "<%= siteUrl %>/"
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FinancialService",
      "name": "<%= content.brandName || 'Trường Giang' %> Broker & Prop Firm",
      "url": "<%= siteUrl %>/"
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        <% faqItems.forEach(function(item, index) { %>
        {
          "@type": "Question",
          "name": "<%- item.question.replace(/"/g, '\\"') %>",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<%- item.answer.replace(/"/g, '\\"') %>"
          }
        }<%= index < faqItems.length - 1 ? ',' : '' %>
        <% }) %>
      ]
    }
    </script>

    <!-- Facebook Pixel -->
    <% const activePixelId = content.facebookPixelId || envFbPixelId; %>
    <% if (activePixelId) { %>
    <script>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '<%= activePixelId %>');
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none"
      src="https://www.facebook.com/tr?id=<%= activePixelId %>&ev=PageView&noscript=1"
    /></noscript>
    <% } %>
</head>
<body>
    <a href="#main-content" class="skip-link">Bỏ qua đến nội dung chính</a>

    <!-- Header -->
    <header class="header">
        <div class="container header-inner">
            <div class="logo">
                <span class="brand-text" style="color: <%= content.brandColor || '#4B5563' %>"><%= content.brandName || 'Gold Smith Tran' %></span>
                <span class="brand-tagline"><%= content.brandTagline || 'Nhà Giả Kim Tài Chính' %></span>
            </div>
            <nav class="desktop-nav" aria-label="Điều hướng chính">
                <a href="#products">Sản phẩm</a>
                <a href="#prop-firm">Prop Firm</a>
                <a href="#platform">Nền tảng</a>
                <a href="#contact">Tư vấn</a>
                <a href="#faq">FAQ</a>
            </nav>
            <div class="header-right">
                <div class="header-actions">
                    <a href="/login" class="btn-text">Đăng nhập</a>
                    <a href="#contact" class="btn btn-primary btn-sm">Bắt đầu giao dịch</a>
                </div>
            </div>
            <button class="mobile-menu-btn" id="mobileMenuBtn" type="button" aria-label="Mở menu" aria-expanded="false" aria-controls="mobileNav">☰</button>
        </div>
    </header>

    <!-- Mobile Nav -->
    <nav class="mobile-nav" id="mobileNav" aria-label="Điều hướng di động">
        <a href="#products">Sản phẩm</a>
        <a href="#prop-firm">Prop Firm</a>
        <a href="#platform">Nền tảng</a>
        <a href="#contact">Tư vấn</a>
        <a href="#faq">FAQ</a>
        <a href="/login" class="btn btn-outline">Đăng nhập</a>
        <a href="#contact" class="btn btn-primary">Bắt đầu giao dịch</a>
    </nav>

    <main id="main-content">

    <!-- Hero Section -->
    <section class="hero section-animate" aria-labelledby="hero-title">
        <div class="container hero-inner">
            <div class="hero-content">
                <div class="eyebrow">Nền tảng giao dịch tài chính cho trader hiện đại</div>
                <h1 class="hero-headline" id="hero-title"><%= content.heroHeadline %></h1>
                <p class="hero-subheadline"><%= content.heroSubheadline %></p>
                <div class="hero-cta-group">
                    <a href="#contact" class="btn btn-primary btn-lg"><%= content.heroCta1 || 'Bắt đầu giao dịch' %></a>
                    <a href="#prop-firm" class="btn btn-outline btn-lg"><%= content.heroCta2 || 'Khám phá chương trình cấp vốn' %></a>
                </div>
                <p class="trust-microcopy">Tư vấn điều kiện tài khoản, chi phí và quản trị rủi ro trước khi giao dịch.</p>
                <div class="hero-proof-row" aria-label="Các điểm nổi bật">
                    <div class="proof-item">
                        <span class="proof-value">0.0</span>
                        <span class="proof-label">Spread từ pip</span>
                    </div>
                    <div class="proof-item">
                        <span class="proof-value">&lt;30ms</span>
                        <span class="proof-label">Khớp lệnh mục tiêu</span>
                    </div>
                    <div class="proof-item">
                        <span class="proof-value">24/7</span>
                        <span class="proof-label">Hỗ trợ trader</span>
                    </div>
                </div>
            </div>
            <div class="hero-visual">
                <% if (content.heroImage) { %>
                <div class="hero-visual-card">
                    <img src="<%= content.heroImage %>" alt="Nền tảng giao dịch <%= content.brandName || 'Trường Giang' %>" class="hero-image">
                    <div class="hero-note">
                        <strong>Risk-first</strong>
                        <span>Theo dõi vốn, drawdown và hiệu suất rõ ràng.</span>
                    </div>
                </div>
                <% } else { %>
                <div class="hero-visual-card">
                    <img src="/img/trading-dashboard.png" alt="Minh họa dashboard giao dịch với biểu đồ giá và chỉ số rủi ro" class="hero-image">
                    <div class="hero-note">
                        <strong>Risk-first</strong>
                        <span>Theo dõi vốn, drawdown và hiệu suất rõ ràng.</span>
                    </div>
                </div>
                <% } %>
            </div>
        </div>
    </section>

    <!-- Quick Benefits (Chips) -->
    <section class="benefits section-light" aria-label="Lợi ích nhanh">
        <div class="container">
            <div class="benefits-grid">
                <% benefitCards.forEach(function(card, index) { %>
                <article class="benefit-card">
                    <span class="benefit-mark"><%= index + 1 %></span>
                    <h3><%= card.title %></h3>
                    <p><%= card.description || 'Điều kiện rõ ràng, phù hợp với trader cần kiểm soát rủi ro.' %></p>
                </article>
                <% }) %>
            </div>
        </div>
    </section>

    <!-- Trust Section -->
    <section class="trust section-animate">
        <div class="container">
            <div class="section-heading-row">
                <div>
                    <div class="section-kicker">Minh bạch trước khi vào lệnh</div>
                    <h2 class="section-title">Được xây dựng cho trader cần dữ liệu rõ ràng</h2>
                </div>
                <p class="section-desc">Mọi điều kiện tài khoản, phí, quy tắc giao dịch và giới hạn rủi ro cần được trình bày công khai trước khi bạn ra quyết định.</p>
            </div>
            
            <div class="stats-grid">
                <div class="stat-item">
                    <div class="stat-num">50K+</div>
                    <div class="stat-label">Trader Hoạt động</div>
                </div>
                <div class="stat-item">
                    <div class="stat-num">0.0</div>
                    <div class="stat-label">Spread từ (pip)</div>
                </div>
                <div class="stat-item">
                    <div class="stat-num">24/7</div>
                    <div class="stat-label">Hỗ trợ Chuyên nghiệp</div>
                </div>
                <div class="stat-item">
                    <div class="stat-num">&lt;30ms</div>
                    <div class="stat-label">Tốc độ Khớp lệnh</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Products / Broker -->
    <section id="products" class="products section-light section-animate">
        <div class="container">
            <div class="products-inner">
                <div class="product-info">
                    <div class="section-kicker">Forex Broker</div>
                    <h2 class="section-title">Tài khoản giao dịch rõ chi phí, dễ so sánh</h2>
                    <p>Chọn môi trường giao dịch phù hợp với vốn, phong cách và mức chấp nhận rủi ro của bạn.</p>
                    <ul class="feature-list">
                        <li>Spread cạnh tranh, cấu trúc phí dễ kiểm tra</li>
                        <li>Đa dạng sản phẩm giao dịch: Forex, CFD, Crypto</li>
                        <li>Tài khoản demo và live cho từng giai đoạn</li>
                        <li>Phù hợp cho trader có vốn cá nhân</li>
                    </ul>
                    <a href="#contact" class="btn btn-primary mt-4">Mở tài khoản giao dịch</a>
                </div>
                
                <div class="pricing-table-wrapper">
                    <table class="pricing-table">
                        <thead>
                            <tr>
                                <th>Tiêu chí</th>
                                <th>Standard</th>
                                <th>Pro</th>
                                <th>ECN</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Spread</td>
                                <td>Từ 1.0 pips</td>
                                <td>Từ 0.5 pips</td>
                                <td>Từ 0.0 pips</td>
                            </tr>
                            <tr>
                                <td>Hoa hồng</td>
                                <td>Không</td>
                                <td>Theo điều kiện</td>
                                <td>$3/lot</td>
                            </tr>
                            <tr>
                                <td>Nền tảng</td>
                                <td>MT5/Web/App</td>
                                <td>MT5/cTrader</td>
                                <td>MT5/cTrader</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>

    <!-- Platform -->
    <section id="platform" class="platform-showcase section-animate">
        <div class="container platform-inner">
            <div class="platform-copy">
                <div class="section-kicker">Nền tảng giao dịch</div>
                <h2 class="section-title">Theo dõi thị trường và tài khoản trên một luồng gọn</h2>
                <p>Giao diện được thiết kế để trader xem nhanh trạng thái tài khoản, điều kiện thử thách, biến động thị trường và kênh hỗ trợ khi cần tư vấn.</p>
                <ul class="platform-list">
                    <li>Tổng quan vốn, drawdown và hiệu suất</li>
                    <li>Luồng đăng ký, nạp tiền, tư vấn dễ theo dõi</li>
                    <li>Tối ưu cho mobile, tablet và desktop</li>
                </ul>
                <a href="#contact" class="btn btn-primary">Nhận tư vấn nền tảng</a>
            </div>
            <div class="platform-media">
                <img src="/img/mobile-trading.png" alt="Minh họa ứng dụng giao dịch mobile và bảng thông tin tài khoản" class="platform-image" loading="lazy">
            </div>
        </div>
    </section>

    <!-- Prop Firm -->
    <section id="prop-firm" class="prop-firm section-animate">
        <div class="container">
            <div class="section-kicker text-center">Prop Firm</div>
            <h2 class="section-title text-center">Chương Trình Cấp Vốn (Prop Firm)</h2>
            <p class="section-desc text-center">Tiếp cận tài khoản cấp vốn khi vượt qua thử thách theo quy tắc đánh giá, drawdown và chia sẻ lợi nhuận được công bố rõ ràng.</p>
            
            <div class="cards-grid">
                <div class="pricing-card">
                    <h3>Challenge 1 Bước</h3>
                    <div class="price">Phase duy nhất</div>
                    <ul>
                        <li>Mục tiêu lợi nhuận: 10%</li>
                        <li>Max Drawdown: 6%</li>
                        <li>Daily Drawdown: 4%</li>
                        <li>Profit Split: 80%</li>
                    </ul>
                    <a href="#contact" class="btn btn-outline full-width mt-4">Chọn gói này</a>
                </div>
                <div class="pricing-card featured">
                    <div class="badge">Phổ biến nhất</div>
                    <h3>Challenge 2 Bước</h3>
                    <div class="price">Đánh giá 2 Phase</div>
                    <ul>
                        <li>Mục tiêu lợi nhuận: 8% / 5%</li>
                        <li>Max Drawdown: 10%</li>
                        <li>Daily Drawdown: 5%</li>
                        <li>Profit Split: Lên đến 90%</li>
                    </ul>
                    <a href="#contact" class="btn btn-primary full-width mt-4">Chọn gói này</a>
                </div>
                <div class="pricing-card">
                    <h3>Advanced</h3>
                    <div class="price">Cho Pro Trader</div>
                    <ul>
                        <li>Không giới hạn thời gian</li>
                        <li>Điều kiện linh hoạt</li>
                        <li>Hỗ trợ 1-1</li>
                        <li>Scale vốn theo lợi nhuận</li>
                    </ul>
                    <a href="#contact" class="btn btn-outline full-width mt-4">Chọn gói này</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Process -->
    <section class="process section-light section-animate">
        <div class="container">
            <div class="section-kicker text-center">Quy trình</div>
            <h2 class="section-title text-center">Quy trình bắt đầu dễ dàng</h2>
            
            <div class="process-grid">
                <% processCards.forEach(function(card, index) { %>
                <div class="process-step">
                    <div class="step-num"><%= index + 1 %></div>
                    <h3><%= card.title %></h3>
                    <p><%= card.description %></p>
                </div>
                <% }) %>
            </div>
            
            <div class="text-center mt-4">
                <a href="#contact" class="btn btn-primary btn-lg">Tạo tài khoản ngay</a>
            </div>
        </div>
    </section>

    <!-- Lead Form -->
    <section id="contact" class="contact-section section-animate">
        <div class="container">
            <div class="contact-inner">
                <div class="contact-info">
                    <div class="section-kicker">Liên hệ tư vấn</div>
                    <h2 class="section-title">Nhận Tư Vấn Miễn Phí</h2>
                    <p>Để lại thông tin, đội ngũ chuyên gia của chúng tôi sẽ liên hệ hỗ trợ bạn chọn tài khoản hoặc chương trình Prop Firm phù hợp nhất.</p>
                    <ul class="contact-perks mt-4">
                        <li>Tư vấn 1-1 miễn phí</li>
                        <li>Giải đáp thắc mắc về phí, spread và drawdown</li>
                        <li>Hướng dẫn nền tảng chi tiết</li>
                    </ul>
                    <img src="/img/advisor-session.png" alt="Minh họa buổi tư vấn chọn tài khoản và quản trị rủi ro" class="contact-image" loading="lazy">
                </div>
                <div class="contact-form-wrapper">
                    <form id="leadForm" class="lead-form">
                        <div class="form-group">
                            <label>Họ và Tên *</label>
                            <input type="text" name="name" required placeholder="Nhập họ tên của bạn">
                        </div>
                        <div class="form-group">
                            <label>Số điện thoại *</label>
                            <input type="tel" name="phone" required placeholder="Nhập số điện thoại">
                        </div>
                        <div class="form-group">
                            <label>Nội dung tư vấn *</label>
                            <textarea name="message" required maxlength="1000" placeholder="Nhập nội dung bạn cần tư vấn"></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary full-width" id="submitBtn">Nhận tư vấn ngay</button>
                        <div id="formMsg" class="form-msg"></div>
                        <p class="microcopy text-center mt-2">Thông tin của bạn chỉ được dùng để tư vấn dịch vụ phù hợp. Không chia sẻ dữ liệu cho bên thứ ba.</p>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="faq-section bg-white section-animate">
        <div class="container">
            <div class="section-kicker text-center">FAQ</div>
            <h2 class="section-title text-center">Câu hỏi thường gặp</h2>
            <div class="faq-list">
                <% faqItems.forEach(function(item) { %>
                <div class="faq-item">
                    <h3><%= item.question %></h3>
                    <p><%= item.answer %></p>
                </div>
                <% }) %>
            </div>
        </div>
    </section>

    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col brand-col">
                    <div class="logo-text"><%= content.footerBrand || content.brandName || 'Gold Smith Tran' %></div>
                    <p class="brand-tagline footer-tagline"><%= content.brandTagline || 'Nhà Giả Kim Tài Chính' %></p>
                    <p class="mt-2">Nền tảng giao dịch tài chính minh bạch cho trader hiện đại.</p>
                </div>
                <div class="footer-col">
                    <h4>Sản phẩm</h4>
                    <a href="#">Forex Broker</a>
                    <a href="#">Prop Firm Challenge</a>
                    <a href="#">Nền tảng giao dịch</a>
                </div>
                <div class="footer-col">
                    <h4>Hỗ trợ</h4>
                    <a href="#">Trung tâm trợ giúp</a>
                    <a href="#">Liên hệ</a>
                    <a href="#">FAQ</a>
                </div>
                <div class="footer-col">
                    <h4>Pháp lý</h4>
                    <a href="#">Điều khoản dịch vụ</a>
                    <a href="#">Chính sách bảo mật</a>
                    <a href="#">Cảnh báo rủi ro</a>
                </div>
            </div>
            
            <div class="footer-disclaimer mt-4">
                <p><strong>Cảnh báo rủi ro:</strong> <%= content.footerDisclaimer || 'Giao dịch ngoại hối, CFD và các sản phẩm phái sinh có mức độ rủi ro cao và có thể không phù hợp với mọi nhà đầu tư.' %></p>
            </div>
            
            <div class="footer-bottom">
                <p>&copy; 2026 <%= content.footerBrand || content.brandName || 'Gold Smith Tran' %>. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <!-- Floating Contact Buttons -->
    <div class="floating-contact">
        <a href="<%= content.zaloUrl %>" target="_blank" class="float-btn zalo-btn" title="Chat Zalo">
            Zalo
        </a>
        <a href="tel:<%= content.phoneNumber %>" class="float-btn phone-btn" title="Gọi điện">
            📞
        </a>
    </div>

    <script src="/js/main.js"></script>
</body>
</html>
